{
  "info": {
    "name": "API Lanchonete - Projeto Back-End",
    "description": "Coleção completa de testes da API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "T01 - Login válido (POSITIVO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna token', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.accessToken).to.exist;",
                  "    pm.collectionVariables.set('token', json.accessToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente@teste.com\",\n  \"senha\": \"Senha@123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "T02 - Login com senha inválida (NEGATIVO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('Retorna erro padrão', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.error).to.equal('CREDENCIAIS_INVALIDAS');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente@teste.com\",\n  \"senha\": \"SenhaErrada\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "T03 - Registrar novo usuário (POSITIVO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Pedro Novo\",\n  \"email\": \"pedro@teste.com\",\n  \"senha\": \"Senha@123\",\n  \"perfil\": \"CLIENTE\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/registrar",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "registrar"]
            }
          }
        },
        {
          "name": "T04 - Registrar com email duplicado (NEGATIVO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409', () => pm.response.to.have.status(409));",
                  "pm.test('Erro de conflito', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.error).to.equal('USUARIO_JA_EXISTE');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Duplicado\",\n  \"email\": \"cliente@teste.com\",\n  \"senha\": \"Senha@123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/registrar",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "registrar"]
            }
          }
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "T05 - Criar pedido válido (POSITIVO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Retorna pedidoId', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.pedidoId).to.exist;",
                  "    pm.collectionVariables.set('pedidoId', json.pedidoId);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"canalPedido\": \"TOTEM\",\n  \"itens\": [\n    {\"produtoId\": 1, \"quantidade\": 2},\n    {\"produtoId\": 3, \"quantidade\": 1}\n  ],\n  \"formaPagamento\": \"PIX\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/pedidos",
              "host": ["{{baseUrl}}"],
              "path": ["pedidos"]
            }
          }
        },
        {
          "name": "T06 - Criar pedido sem token (NEGATIVO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"canalPedido\": \"APP\",\n  \"itens\": [{\"produtoId\": 1, \"quantidade\": 1}],\n  \"formaPagamento\": \"CARTAO\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/pedidos",
              "host": ["{{baseUrl}}"],
              "path": ["pedidos"]
            }
          }
        },
        {
          "name": "T07 - Criar pedido com canal inválido (NEGATIVO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
                  "pm.test('Erro de validação', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.error).to.equal('CANAL_INVALIDO');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"canalPedido\": \"INVALIDO\",\n  \"itens\": [{\"produtoId\": 1, \"quantidade\": 1}],\n  \"formaPagamento\": \"PIX\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/pedidos",
              "host": ["{{baseUrl}}"],
              "path": ["pedidos"]
            }
          }
        },
        {
          "name": "T08 - Listar pedidos (POSITIVO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna array', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/pedidos",
              "host": ["{{baseUrl}}"],
              "path": ["pedidos"]
            }
          }
        },
        {
          "name": "T09 - Filtrar pedidos por canal (POSITIVO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/pedidos?canalPedido=TOTEM",
              "host": ["{{baseUrl}}"],
              "path": ["pedidos"],
              "query": [
                {
                  "key": "canalPedido",
                  "value": "TOTEM"
                }
              ]
            }
          }
        },
        {
          "name": "T10 - Processar pagamento aprovado (POSITIVO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Pagamento processado', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/pedidos/{{pedidoId}}/pagamento",
              "host": ["{{baseUrl}}"],
              "path": ["pedidos", "{{pedidoId}}", "pagamento"]
            }
          }
        },
        {
          "name": "Produtos",
          "item": [
            {
              "name": "T11 - Listar produtos (cardápio) (POSITIVO)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));",
                      "pm.test('Retorna array', () => {",
                      "    const json = pm.response.json();",
                      "    pm.expect(json).to.be.an('array');",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/produtos",
                  "host": ["{{baseUrl}}"],
                  "path": ["produtos"]
                }
              }
            }
          ]
        }
      ]
    }
  ]
}